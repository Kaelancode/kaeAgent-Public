# Copy to .env or export the variables you need before running an example.

# LLM providers. Set at least one key for examples that call a model.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=

# Optional provider base URLs for gateways or compatible endpoints.
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GEMINI_BASE_URL=
DASHSCOPE_BASE_URL=

# General example logging.
LOG_LEVEL=info

# Shared tracing selector used by examples that call exampleutil.SetupTracerFromEnv.
# Valid values: stdout, jaeger, langfuse, mlflow, opik.
TRACE_BACKEND=
OTEL_SERVICE_NAME=agent-sdk-example

# Jaeger / generic OTLP gRPC tracing.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# MLflow OTLP HTTP tracing.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=localhost:5000
OTEL_EXPORTER_OTLP_INSECURE=true
MLFLOW_EXPERIMENT_ID=0
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Langfuse tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_OTEL_TRACES_ENDPOINT=

# Opik tracing.
OPIK_ENDPOINT=www.comet.com
OPIK_URL_PATH=/opik/api/v1/private/otel/v1/traces
OPIK_PROJECT=default
OPIK_WORKSPACE=default
OPIK_API_KEY=
OPIK_INSECURE=false

# Optional persistence used by examples/traced.
STORE_BACKEND=
STORE_DIR=./data
